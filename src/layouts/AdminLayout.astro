---
import "@/styles/global.css";
import { getAllSeasons, resolveAdminSeason } from "@/lib/season";
import { readSession, getUserById } from "@/lib/auth";

interface Props {
  title: string;
  current?: string;
}
const { title, current } = Astro.props;

const seasons = await getAllSeasons();
const activeSeason = await resolveAdminSeason(Astro.cookies);
const session = readSession(Astro.cookies);
const currentUser = session ? await getUserById(session.userId) : null;
const isAdmin = session?.role === "admin";

const nav = [
  { href: "/admin", label: "Dashboard", key: "home" },
  { href: "/admin/matches", label: "Partite", key: "matches" },
  { href: "/admin/news", label: "News", key: "news" },
  { href: "/admin/squad", label: "Rosa", key: "squad" },
  { href: "/admin/staff", label: "Staff", key: "staff" },
  { href: "/admin/sponsors", label: "Sponsor", key: "sponsors" },
  { href: "/admin/teams", label: "Squadre", key: "teams" },
  { href: "/admin/seasons", label: "Stagioni", key: "seasons" },
  ...(isAdmin ? [{ href: "/admin/users", label: "Utenti", key: "users" }] : []),
];
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} — Admin Colleferro</title>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-nero text-panna font-sans antialiased min-h-screen">
    <header class="border-b border-carbone bg-grafite">
      <div class="max-w-6xl mx-auto px-5 py-4 flex items-center justify-between gap-6">
        <a href="/admin" class="font-display text-panna tracking-wide">
          <span class="text-[0.65rem] tracking-[0.2em] text-fumo uppercase block">Admin</span>
          <span class="text-lg">Colleferro Calcio</span>
        </a>
        <nav class="hidden md:flex items-center gap-1 flex-1 justify-center">
          {nav.map((n) => (
            <a
              href={n.href}
              class={`px-3 py-2 font-display text-xs tracking-wider uppercase transition-colors ${
                current === n.key ? "text-oro" : "text-panna hover:text-oro"
              }`}
            >
              {n.label}
            </a>
          ))}
        </nav>
        <form method="post" action="/admin/season" class="flex items-center gap-2">
          <span class="font-display text-[0.65rem] tracking-[0.2em] uppercase text-fumo">Stagione</span>
          <select name="year" onchange="this.form.submit()" class="bg-nero border border-carbone px-2 py-1 text-panna text-xs font-display">
            {seasons.map((s) => (
              <option value={s.year} selected={s.year === activeSeason}>
                {s.label}{s.isCurrent ? " ★" : ""}
              </option>
            ))}
          </select>
        </form>
        <form method="post" action="/admin/logout" class="flex items-center gap-3">
          {currentUser && (
            <span class="hidden md:inline text-fumo text-xs font-display tracking-wider">
              <span class="text-panna">{currentUser.email}</span>
              <span class="text-oro ml-1">· {currentUser.role}</span>
            </span>
          )}
          <button type="submit" class="btn btn-ghost text-xs">Esci</button>
        </form>
      </div>
    </header>
    <main class="max-w-6xl mx-auto px-5 py-10">
      <slot />
    </main>
  </body>
</html>
