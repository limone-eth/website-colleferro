---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";

const galleries = [
  { title: "Colleferro — Aranova 1-0", date: "13 Apr 2026", count: 24 },
  { title: "Allenamento a porte aperte", date: "10 Apr 2026", count: 18 },
  { title: "Presentazione squadra 2025/26", date: "02 Set 2025", count: 42 },
  { title: "Il “Caslini” dall'alto", date: "15 Ago 2025", count: 12 },
];

const videos = [
  { title: "Gli highlights di Colleferro — Aranova", dur: "2:18" },
  { title: "Mister Fumagalli in conferenza stampa", dur: "6:42" },
  { title: "Il gol di Bastianelli al 78’", dur: "0:34" },
];
---

<BaseLayout
  title="Media — Colleferro Calcio"
  description="Foto, video e area accrediti del Colleferro Calcio."
>
  <Hero
    eyebrow="Area Media"
    title="Dentro il Colleferro."
    subtitle="Gallerie fotografiche, highlights, conferenze stampa e richieste accredito. Tutto quello che serve a chi racconta il club."
  />

  <!-- Video -->
  <section class="max-w-7xl mx-auto px-5 lg:px-8 py-20 md:py-24">
    <header class="flex items-end justify-between mb-8 border-b border-carbone pb-4">
      <h2 class="font-display text-3xl md:text-4xl text-panna">Video</h2>
      <a href="#" class="btn btn-ghost text-xs">Canale YouTube</a>
    </header>
    <div class="grid md:grid-cols-3 gap-5">
      {
        videos.map((v) => (
          <article class="group bg-grafite border border-carbone hover:border-rosso/60 transition-colors overflow-hidden">
            <div class="relative aspect-video bg-gradient-to-br from-rosso-deep via-carbone to-nero grid place-items-center">
              <span class="w-14 h-14 rounded-full bg-oro grid place-items-center group-hover:scale-110 transition-transform">
                <svg viewBox="0 0 24 24" class="w-6 h-6 text-nero ml-1 fill-current" aria-hidden="true">
                  <path d="M8 5v14l11-7z" />
                </svg>
              </span>
              <span class="absolute bottom-3 right-3 font-display text-xs bg-nero/80 text-panna px-2 py-1">
                {v.dur}
              </span>
            </div>
            <h3 class="font-display text-base text-panna p-4 leading-tight">{v.title}</h3>
          </article>
        ))
      }
    </div>
  </section>

  <!-- Gallerie -->
  <section class="bg-grafite/40 border-y border-carbone py-20">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <h2 class="font-display text-3xl md:text-4xl text-panna mb-8">Gallerie fotografiche</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {
          galleries.map((g) => (
            <article class="group bg-nero border border-carbone hover:border-rosso/60 transition-colors overflow-hidden">
              <div class="aspect-[4/3] bg-gradient-to-br from-rosso-deep via-carbone to-nero grid place-items-center">
                <svg viewBox="0 0 24 24" class="w-10 h-10 text-oro/40" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <rect x="3" y="5" width="18" height="14" rx="1" />
                  <circle cx="9" cy="11" r="2" />
                  <path d="M3 17l5-5 4 4 3-3 6 6" />
                </svg>
              </div>
              <div class="p-4">
                <p class="text-[0.65rem] font-display tracking-[0.25em] uppercase text-oro">
                  {g.count} foto
                </p>
                <h3 class="font-display text-base text-panna mt-1 leading-tight">
                  {g.title}
                </h3>
                <p class="text-xs text-fumo mt-2">{g.date}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Accrediti -->
  <section class="max-w-4xl mx-auto px-5 lg:px-8 py-20 text-center">
    <p class="font-display text-xs tracking-[0.3em] uppercase text-oro mb-4">Accrediti stampa</p>
    <h2 class="font-display text-3xl md:text-4xl text-panna mb-5">Sei un giornalista o un fotografo?</h2>
    <p class="text-fumo max-w-xl mx-auto leading-relaxed">
      Per richiedere l'accredito per le partite casalinghe, scrivi a <a href="mailto:colleferrocalcio@gmail.com" class="text-oro hover:underline">colleferrocalcio@gmail.com</a> entro il venerdì precedente la gara, allegando tesserino e testata di riferimento.
    </p>
    <a href="mailto:colleferrocalcio@gmail.com" class="btn btn-primary mt-8">Richiedi accredito</a>
  </section>
</BaseLayout>
