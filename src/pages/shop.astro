---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";

const prodotti = [
  { nome: "Maglia Home 2025/26", prezzo: "65 €", badge: "Ufficiale", cat: "Game" },
  { nome: "Maglia Away 2025/26", prezzo: "65 €", badge: "Ufficiale", cat: "Game" },
  { nome: "Maglia Portiere", prezzo: "65 €", badge: "Ufficiale", cat: "Game" },
  { nome: "Tuta Rappresentanza", prezzo: "89 €", badge: "Nuovo", cat: "Training" },
  { nome: "Felpa Cappuccio Rossonera", prezzo: "55 €", cat: "Lifestyle" },
  { nome: "T-shirt 100 anni", prezzo: "25 €", badge: "Edizione Limitata", cat: "Lifestyle" },
  { nome: "Sciarpa Ultras", prezzo: "18 €", cat: "Accessori" },
  { nome: "Cappellino “Caslini”", prezzo: "22 €", cat: "Accessori" },
];
---

<BaseLayout
  title="Shop Ufficiale — Colleferro Calcio"
  description="Maglie gara, kit allenamento e merchandising ufficiale del Colleferro Calcio. Spedizione in tutta Italia."
>
  <Hero
    eyebrow="Shop Ufficiale"
    title="Indossa la tua maglia."
    subtitle="Maglie gara, kit allenamento e merchandising ufficiale. Chi ama il Colleferro lo porta addosso."
    primaryCta={{ label: "Acquista la nuova maglia", href: "#prodotti" }}
  />

  <section id="prodotti" class="max-w-7xl mx-auto px-5 lg:px-8 py-20 md:py-24">
    <div class="flex flex-wrap gap-2 mb-10">
      {
        ["Tutti", "Game", "Training", "Lifestyle", "Accessori"].map((c, i) => (
          <button
            type="button"
            class={`btn text-xs ${i === 0 ? "btn-primary" : "btn-ghost"}`}
          >
            {c}
          </button>
        ))
      }
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {
        prodotti.map((p) => (
          <article class="group bg-grafite border border-carbone hover:border-rosso/60 transition-colors overflow-hidden flex flex-col">
            <div class="relative aspect-square bg-gradient-to-br from-rosso-deep via-carbone to-nero grid place-items-center overflow-hidden">
              <svg viewBox="0 0 120 120" class="w-20 h-20 text-oro/40" fill="currentColor" aria-hidden="true">
                <path d="M40 20L24 28v12l12 4v52h48V44l12-4V28l-16-8-12 6a12 12 0 01-20 0l-8-6z" />
              </svg>
              {p.badge && (
                <span class="absolute top-3 left-3 font-display text-[0.6rem] tracking-[0.2em] uppercase bg-oro text-nero px-2 py-1">
                  {p.badge}
                </span>
              )}
            </div>
            <div class="p-4 flex-1 flex flex-col">
              <p class="font-display text-[0.6rem] tracking-[0.25em] uppercase text-fumo">
                {p.cat}
              </p>
              <h3 class="font-display text-base text-panna mt-1 leading-tight flex-1">
                {p.nome}
              </h3>
              <div class="mt-3 flex items-center justify-between">
                <span class="font-display text-lg text-oro font-bold">{p.prezzo}</span>
                <button type="button" class="btn btn-ghost text-[0.65rem] px-3 py-2">
                  Aggiungi
                </button>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <div class="mt-16 bg-grafite border border-carbone p-6 md:p-8 grid md:grid-cols-3 gap-6 text-center">
      <div>
        <p class="font-display text-xs tracking-[0.25em] uppercase text-oro">Spedizione</p>
        <p class="text-panna mt-2 text-sm">Gratuita sopra i 50 €, consegna 2–4 giorni in tutta Italia.</p>
      </div>
      <div>
        <p class="font-display text-xs tracking-[0.25em] uppercase text-oro">Reso</p>
        <p class="text-panna mt-2 text-sm">30 giorni per cambio taglia o reso. Facile, senza fronzoli.</p>
      </div>
      <div>
        <p class="font-display text-xs tracking-[0.25em] uppercase text-oro">Ritiro in sede</p>
        <p class="text-panna mt-2 text-sm">Vieni al “Caslini” e ritira il tuo ordine direttamente dal club.</p>
      </div>
    </div>
  </section>
</BaseLayout>
