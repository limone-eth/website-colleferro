---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import NewsCard from "@/components/NewsCard.astro";
import { getYouthCategories, getYouthManagement, getYouthNews } from "@/lib/db";
import { getYouthStadium } from "@/lib/settings";
import { getCurrentSeasonYear } from "@/lib/season";
import { CLD } from "@/lib/cloudinary";
import { firstImageFromHtml } from "@/lib/seo";

const season = await getCurrentSeasonYear();
const [categories, management, news, stadium] = await Promise.all([
  getYouthCategories(season),
  getYouthManagement(season),
  getYouthNews(3),
  getYouthStadium(),
]);

const groups = ["Dirigenza", "Tecnico", "Medico"] as const;
const groupLabels: Record<(typeof groups)[number], string> = {
  Dirigenza: "Direzione",
  Tecnico: "Area tecnica",
  Medico: "Area medica",
};

const newsCardImage = (body: string) => {
  const src = firstImageFromHtml(body);
  return src ? (CLD.newsCard(src) ?? src) : undefined;
};
---

<BaseLayout
  title="Settore Giovanile — Colleferro Calcio"
  description="Il settore giovanile del Colleferro Calcio: organigramma, categorie, campo di allenamento e news."
>
  <Hero
    eyebrow="Settore Giovanile"
    title="Costruiamo il futuro"
    subtitle="Le nostre categorie, lo staff, il campo, le partite e i risultati. Tutto quello che riguarda i giovani rossoneri."
  />

  {/* ORGANIGRAMMA */}
  {management.length > 0 && (
    <section class="max-w-7xl mx-auto px-5 lg:px-8 py-20 md:py-24">
      <div class="mb-10">
        <p class="font-display text-xs tracking-[0.3em] uppercase text-oro mb-2">Organigramma</p>
        <h2 class="font-display text-3xl md:text-4xl text-panna">Chi dirige il settore</h2>
      </div>
      <div class="space-y-10">
        {groups.map((g) => {
          const members = management.filter((m) => m.group === g);
          if (members.length === 0) return null;
          return (
            <div>
              <h3 class="font-display text-sm tracking-[0.2em] uppercase text-oro mb-4">{groupLabels[g]}</h3>
              <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {members.map((m) => (
                  <article class="bg-grafite border border-carbone hover:border-rosso/60 transition-colors p-4 flex items-center gap-4">
                    <div class="w-16 aspect-[3/4] bg-nero border border-fumo/20 overflow-hidden grid place-items-center shrink-0">
                      {m.photoUrl ? (
                        <img src={CLD.staffPortrait(m.photoUrl)} alt={m.name} loading="lazy" class="w-full h-full object-cover" />
                      ) : (
                        <svg viewBox="0 0 24 24" class="w-7 h-7 text-panna/40" fill="currentColor" aria-hidden="true">
                          <path d="M12 12a5 5 0 100-10 5 5 0 000 10zm0 2c-4.4 0-8 2.2-8 5v3h16v-3c0-2.8-3.6-5-8-5z" />
                        </svg>
                      )}
                    </div>
                    <div class="min-w-0">
                      <p class="font-display text-[0.65rem] tracking-[0.25em] uppercase text-rosso">{m.role}</p>
                      <h4 class="font-display text-lg text-panna leading-tight mt-1 truncate">{m.name}</h4>
                    </div>
                  </article>
                ))}
              </div>
            </div>
          );
        })}
      </div>
    </section>
  )}

  {/* STADIO */}
  {stadium.name && (
    <section class="bg-grafite/40 border-y border-carbone py-16 md:py-20">
      <div class="max-w-7xl mx-auto px-5 lg:px-8 grid lg:grid-cols-2 gap-10 items-center">
        <div class="aspect-[4/3] bg-grafite border border-carbone overflow-hidden">
          {stadium.photoUrl ? (
            <img src={stadium.photoUrl} alt={stadium.name} loading="lazy" class="w-full h-full object-cover" />
          ) : (
            <div class="w-full h-full grid place-items-center text-fumo">
              <span class="font-display text-xs tracking-[0.25em] uppercase">Foto in arrivo</span>
            </div>
          )}
        </div>
        <div>
          <p class="font-display text-xs tracking-[0.3em] uppercase text-oro mb-3">Il campo</p>
          <h2 class="font-display text-3xl md:text-4xl text-panna mb-4">{stadium.name}</h2>
          {stadium.description && <p class="text-fumo leading-relaxed mb-5 line-clamp-5">{stadium.description}</p>}
          {(stadium.address || stadium.city) && (
            <p class="text-panna text-sm leading-relaxed">
              {stadium.address}{stadium.address && stadium.city ? <br /> : null}
              {stadium.city}
            </p>
          )}
          <div class="mt-6 flex gap-3 flex-wrap">
            <a href="/settore-giovanile/stadio" class="btn btn-primary">Scopri il campo</a>
            {stadium.mapsUrl && (
              <a href={stadium.mapsUrl} target="_blank" rel="noopener" class="btn btn-ghost">Apri su Maps</a>
            )}
          </div>
        </div>
      </div>
    </section>
  )}

  {/* CATEGORIE */}
  <section class="max-w-7xl mx-auto px-5 lg:px-8 py-20 md:py-24">
    <div class="flex items-end justify-between mb-8 border-b border-carbone pb-4">
      <div>
        <p class="font-display text-xs tracking-[0.3em] uppercase text-oro mb-2">Categorie</p>
        <h2 class="font-display text-3xl md:text-4xl text-panna">Le squadre del vivaio</h2>
      </div>
    </div>
    {categories.length === 0 ? (
      <div class="bg-grafite border border-carbone p-10 text-center">
        <p class="text-fumo">Categorie in fase di pubblicazione.</p>
      </div>
    ) : (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {categories.map((c) => (
          <a href={`/settore-giovanile/${c.slug}`} class="group bg-grafite border border-carbone hover:border-rosso/60 p-6 transition-colors block">
            <p class="font-display text-[0.65rem] tracking-[0.3em] uppercase text-oro mb-2">Categoria</p>
            <h3 class="font-display text-2xl text-panna group-hover:text-oro transition-colors">{c.name}</h3>
            {c.description && <p class="text-fumo text-sm mt-3 line-clamp-3">{c.description}</p>}
            <span class="inline-flex items-center gap-2 mt-5 font-display text-xs tracking-[0.2em] uppercase text-oro">
              Scopri
              <svg viewBox="0 0 24 24" class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="square" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    )}
  </section>

  {/* NEWS */}
  {news.length > 0 && (
    <section class="bg-grafite/40 border-t border-carbone py-16 md:py-20">
      <div class="max-w-7xl mx-auto px-5 lg:px-8">
        <div class="flex items-end justify-between mb-8">
          <div>
            <p class="font-display text-xs tracking-[0.3em] uppercase text-oro mb-2">News</p>
            <h2 class="font-display text-3xl md:text-4xl text-panna">Ultime dal settore</h2>
          </div>
          <a href="/settore-giovanile/news" class="btn btn-ghost text-sm">Tutte le news →</a>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {news.map((n) => (
            <NewsCard
              slug={n.slug}
              title={n.title}
              excerpt={n.excerpt}
              date={n.date}
              category={n.category}
              image={newsCardImage(n.body)}
            />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
