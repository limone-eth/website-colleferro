---
import BaseLayout from "@/layouts/BaseLayout.astro";
import NewsCard from "@/components/NewsCard.astro";
import ShareFacebook from "@/components/ShareFacebook.astro";
import { getNewsBySlug, getAllNews } from "@/lib/db";
import { sanitizeArticleHtml } from "@/lib/sanitize";
import { rewriteArticleImages, CLD } from "@/lib/cloudinary";
import { SITE, absoluteUrl, firstImageFromHtml, toIsoDate, jsonLdString } from "@/lib/seo";

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/news");

const post = await getNewsBySlug(slug);
if (!post) return new Response("Not found", { status: 404 });

const all = await getAllNews();
const related = all.filter((n) => n.slug !== post.slug).slice(0, 3);

const base = Astro.site ?? Astro.url;
const shareUrl = absoluteUrl(`/news/${post.slug}`, base);

const bodyImage = firstImageFromHtml(post.body);
const ogImageRaw = bodyImage ? (CLD.articleInline(bodyImage) ?? bodyImage) : SITE.defaultOgImagePath;
const ogImageAbs = /^https?:\/\//i.test(ogImageRaw) ? ogImageRaw : absoluteUrl(ogImageRaw, base);

const publishedTime = toIsoDate(post.dateIso);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  mainEntityOfPage: { "@type": "WebPage", "@id": shareUrl },
  headline: post.title,
  description: post.excerpt,
  image: [ogImageAbs],
  datePublished: publishedTime,
  dateModified: publishedTime,
  author: { "@type": "Person", name: post.author },
  articleSection: post.category,
  publisher: {
    "@type": "Organization",
    name: SITE.name,
    logo: {
      "@type": "ImageObject",
      url: absoluteUrl(SITE.logoPath, base),
    },
  },
  inLanguage: "it-IT",
};
---

<BaseLayout
  title={`${post.title} — Colleferro Calcio`}
  description={post.excerpt}
  ogImage={ogImageAbs}
  ogType="article"
  canonical={shareUrl}
  article={{
    publishedTime,
    modifiedTime: publishedTime,
    author: post.author,
    section: post.category,
  }}
>
  <script type="application/ld+json" slot="jsonld" set:html={jsonLdString(jsonLd)} />
  <article class="bg-nero">
    <header class="relative overflow-hidden border-b border-carbone">
      <div class="absolute inset-0 opacity-30 bg-[radial-gradient(ellipse_at_top_left,_var(--color-rosso)_0%,_transparent_55%)]"></div>
      <div class="absolute -right-20 -top-20 w-[30rem] h-[30rem] rotate-12 stripe-diagonal opacity-[0.06]" aria-hidden="true"></div>

      <div class="relative max-w-3xl mx-auto px-5 lg:px-8 py-20 md:py-24">
        <a href="/news" class="inline-flex items-center gap-2 font-display text-xs tracking-[0.25em] uppercase text-oro hover:text-panna transition-colors mb-8">
          <svg viewBox="0 0 24 24" class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M19 12H5M11 5l-7 7 7 7" stroke-linecap="square" />
          </svg>
          Tutte le news
        </a>
        <p class="flex items-center gap-3 mb-5">
          <span class="font-display text-[0.65rem] tracking-[0.25em] uppercase bg-rosso text-panna px-3 py-1">
            {post.category}
          </span>
          <time class="font-display text-xs tracking-[0.25em] uppercase text-fumo" datetime={post.dateIso}>
            {post.date}
          </time>
        </p>
        <h1 class="font-display text-3xl md:text-5xl lg:text-6xl font-bold text-panna leading-[1.05]">
          {post.title}
        </h1>
        <p class="mt-5 text-fumo text-sm">Di {post.author}</p>
      </div>
    </header>

    <div class="max-w-3xl mx-auto px-5 lg:px-8 py-16 md:py-20">
      <div class="article-body text-lg leading-relaxed text-panna/90" set:html={rewriteArticleImages(sanitizeArticleHtml(post.body))} />

      <div class="mt-14 pt-8 border-t border-carbone flex items-center justify-between gap-4">
        <a href="/news" class="btn btn-ghost text-sm">
          <svg viewBox="0 0 24 24" class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M19 12H5M11 5l-7 7 7 7" stroke-linecap="square" />
          </svg>
          Altre news
        </a>
        <div class="flex gap-2">
          <ShareFacebook url={shareUrl} />
        </div>
      </div>
    </div>

    <section class="bg-grafite/40 border-t border-carbone py-16 md:py-20">
      <div class="max-w-7xl mx-auto px-5 lg:px-8">
        <h2 class="font-display text-2xl md:text-3xl text-panna mb-8">Continua a leggere</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {
            related.map((n) => (
              <NewsCard
                slug={n.slug}
                title={n.title}
                excerpt={n.excerpt}
                date={n.date}
                category={n.category}
              />
            ))
          }
        </div>
      </div>
    </section>
  </article>
</BaseLayout>

<style is:global>
  .article-body p { margin-bottom: 1.1em; }
  .article-body h2 { font-family: "Oswald", sans-serif; font-size: 1.75rem; margin: 1.6em 0 0.6em; color: var(--color-panna, #F4EADF); }
  .article-body h3 { font-family: "Oswald", sans-serif; font-size: 1.35rem; margin: 1.4em 0 0.5em; color: var(--color-panna, #F4EADF); }
  .article-body ul, .article-body ol { padding-left: 1.4em; margin-bottom: 1.1em; }
  .article-body li { margin-bottom: 0.4em; }
  .article-body blockquote { border-left: 3px solid var(--color-rosso, #B3001F); padding-left: 1em; color: var(--color-fumo, #9A8E80); font-style: italic; margin: 1.2em 0; }
  .article-body a { color: var(--color-oro, #D4A64A); text-decoration: underline; }
  .article-body hr { border: 0; border-top: 1px solid var(--color-carbone, #2B2B2B); margin: 1.6em 0; }
  .article-body img { max-width: 100%; height: auto; margin: 1.4em auto; display: block; border: 1px solid var(--color-carbone, #2B2B2B); }
</style>
