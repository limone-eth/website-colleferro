---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { requireAdmin } from "@/lib/auth";
import { db } from "@/lib/db";
import { upsertTeam } from "@/lib/db-write";
import { formatSeason } from "@/lib/season";
import ImageUploader from "@/components/admin/ImageUploader.astro";
import { assertValidImageUrl, IMAGE_RULES } from "@/lib/image-validation";

const guard = requireAdmin(Astro);
if (guard) return guard;

const { id } = Astro.params;
if (!id) return Astro.redirect("/admin/teams");
const idNum = Number(id);

const { rows } = await db.execute({ sql: "SELECT * FROM teams WHERE id = ?", args: [idNum] });
if (!rows[0]) return new Response("Squadra non trovata", { status: 404 });
const r = rows[0];
const teamSeason = Number(r.season);

let error: string | undefined;

if (Astro.request.method === "POST") {
  const f = await Astro.request.formData();
  try {
    const name = String(f.get("name") ?? "").trim();
    const short = String(f.get("short") ?? "").trim().toUpperCase();
    if (!name) throw new Error("Nome squadra obbligatorio.");
    if (!short || short.length > 6) throw new Error("Sigla obbligatoria (max 6 caratteri).");
    const crestUrl = (f.get("crestUrl") as string) || null;
    await assertValidImageUrl(crestUrl, { ...IMAGE_RULES.teamCrest, requiredFolder: "colleferro/teams" });
    await upsertTeam({ season: teamSeason, name, short, crestUrl }, idNum);
    return Astro.redirect("/admin/teams");
  } catch (e) {
    error = (e as Error).message;
  }
}
---

<AdminLayout title="Modifica squadra" current="teams">
  <h1 class="font-display text-2xl text-panna mb-2">Modifica squadra</h1>
  <p class="text-fumo text-xs mb-6">Stagione {formatSeason(teamSeason)}</p>

  <form method="post" class="bg-grafite border border-carbone p-6 grid md:grid-cols-4 gap-4 items-end">
    {error && <p class="text-sm text-rosso border border-rosso/40 bg-rosso/10 px-3 py-2 md:col-span-4">{error}</p>}
    <label class="block md:col-span-3">
      <span class="font-display text-xs uppercase text-fumo block mb-1">Nome</span>
      <input name="name" required value={r.name as string} class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
    </label>
    <label class="block">
      <span class="font-display text-xs uppercase text-fumo block mb-1">Sigla</span>
      <input name="short" required maxlength="6" value={r.short as string} class="w-full bg-nero border border-carbone px-3 py-2 text-panna uppercase" />
    </label>
    <div class="md:col-span-4">
      <ImageUploader
        name="crestUrl"
        value={(r.crest_url as string | null) ?? ""}
        folder="colleferro/teams"
        label="Stemma squadra"
        hint="quadrato 1:1 · png/svg/webp (trasparenza consigliata) o jpg · max 2MB"
        formats={IMAGE_RULES.teamCrest.allowedFormats}
        maxBytes={IMAGE_RULES.teamCrest.maxBytes}
        cropAspectRatio={1}
      />
    </div>
    <div class="md:col-span-4 flex gap-3 pt-2">
      <button type="submit" class="btn btn-primary">Salva</button>
      <a href="/admin/teams" class="btn btn-ghost">Annulla</a>
    </div>
  </form>
</AdminLayout>
