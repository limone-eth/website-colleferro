---
import AdminLayout from "@/layouts/AdminLayout.astro";
import MatchForm from "@/components/admin/MatchForm.astro";
import { requireAdmin } from "@/lib/auth";
import { db, getStandings, getAllMatches } from "@/lib/db";
import { upsertMatch } from "@/lib/db-write";
import { dateFieldsFromInput, matchdayLabel, parseMatchdayNumber, shortFor } from "@/lib/match-utils";

const guard = requireAdmin(Astro);
if (guard) return guard;

let error: string | undefined;

if (Astro.request.method === "POST") {
  const f = await Astro.request.formData();
  try {
    const matchdayNum = Number(f.get("matchdayNum") ?? 0);
    if (!matchdayNum || matchdayNum < 1) throw new Error("Giornata non valida.");

    const { rows } = await db.execute({
      sql: "SELECT matchday FROM matches WHERE matchday LIKE ?",
      args: [`${matchdayNum}ª%`],
    });
    if (rows.length > 0) throw new Error(`Giornata ${matchdayNum} è già inserita.`);

    const homeName = String(f.get("homeName") ?? "").trim();
    const awayName = String(f.get("awayName") ?? "").trim();
    if (!homeName || !awayName) throw new Error("Seleziona entrambe le squadre.");
    if (homeName === awayName) throw new Error("Casa e ospite non possono coincidere.");

    const fields = dateFieldsFromInput(String(f.get("matchDate") ?? ""), String(f.get("matchTime") ?? "15:00"));

    await upsertMatch({
      id: String(f.get("id") ?? "").trim(),
      matchday: matchdayLabel(matchdayNum),
      competition: String(f.get("competition") ?? ""),
      date: fields.date,
      dateLong: fields.dateLong,
      time: fields.time,
      homeName,
      homeShort: shortFor(homeName),
      awayName,
      awayShort: shortFor(awayName),
      venue: String(f.get("venue") ?? ""),
      status: String(f.get("status") ?? "upcoming") as "upcoming" | "live" | "finished",
      scoreHome: f.get("scoreHome") ? Number(f.get("scoreHome")) : null,
      scoreAway: f.get("scoreAway") ? Number(f.get("scoreAway")) : null,
      ticketUrl: (f.get("ticketUrl") as string) || null,
    });
    return Astro.redirect("/admin/matches");
  } catch (e) {
    error = (e as Error).message;
  }
}

const [standings, allMatches] = await Promise.all([getStandings(), getAllMatches()]);
const teams = standings.map((s) => s.team);
if (!teams.includes("Colleferro")) teams.unshift("Colleferro");
const usedMatchdays = allMatches
  .map((m) => parseMatchdayNumber(m.matchday))
  .filter((n): n is number => n !== null);
---

<AdminLayout title="Nuova partita" current="matches">
  <h1 class="font-display text-2xl text-panna mb-6">Nuova partita</h1>
  <MatchForm action="/admin/matches/new" error={error} teams={teams} usedMatchdays={usedMatchdays} />
</AdminLayout>
