---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { requireAdmin } from "@/lib/auth";
import { getAllMatches, getStandings } from "@/lib/db";
import { deleteMatch } from "@/lib/db-write";

const guard = requireAdmin(Astro);
if (guard) return guard;

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("action");
  if (action === "delete") {
    const id = String(form.get("id") ?? "");
    if (id) await deleteMatch(id);
    return Astro.redirect(`/admin/matches${Astro.url.search}`);
  }
}

const filter = Astro.url.searchParams.get("team") ?? "Colleferro";
const allMatches = await getAllMatches();
const teams = [...new Set(allMatches.flatMap((m) => [m.home.name, m.away.name]))].sort();

const matches = filter === "all"
  ? allMatches
  : allMatches.filter((m) => m.home.name === filter || m.away.name === filter);

// compute Colleferro position for a quick summary banner
const standings = await getStandings();
const colPos = standings.find((s) => s.team === "Colleferro");
---

<AdminLayout title="Partite" current="matches">
  <div class="flex items-end justify-between mb-6 border-b border-carbone pb-4">
    <div>
      <p class="font-display text-[0.65rem] tracking-[0.25em] uppercase text-oro mb-1">Partite</p>
      <h1 class="font-display text-2xl text-panna">Calendario e risultati</h1>
      {colPos && (
        <p class="text-fumo text-xs mt-2">
          Classifica derivata — Colleferro <span class="text-oro font-display">{colPos.pos}º</span> con <span class="text-oro font-display">{colPos.pts}</span> punti
        </p>
      )}
    </div>
    <a href="/admin/matches/new" class="btn btn-primary">Nuova partita</a>
  </div>

  <form method="get" class="mb-6 flex gap-3 items-center">
    <label class="flex items-center gap-2">
      <span class="font-display text-xs tracking-wider uppercase text-fumo">Filtra squadra:</span>
      <select name="team" class="bg-nero border border-carbone px-3 py-2 text-panna text-sm" onchange="this.form.submit()">
        <option value="all" selected={filter === "all"}>Tutte ({allMatches.length})</option>
        {teams.map((t) => (
          <option value={t} selected={filter === t}>{t}</option>
        ))}
      </select>
    </label>
    <span class="text-xs text-fumo">{matches.length} partite mostrate</span>
  </form>

  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="border-b border-carbone">
        <tr class="text-left text-fumo font-display text-xs tracking-wider uppercase">
          <th class="py-3 pr-4">Giornata</th>
          <th class="py-3 pr-4">Partita</th>
          <th class="py-3 pr-4">Data</th>
          <th class="py-3 pr-4">Stato</th>
          <th class="py-3 pr-4">Risultato</th>
          <th class="py-3"></th>
        </tr>
      </thead>
      <tbody>
        {matches.map((m) => (
          <tr class="border-b border-carbone/60">
            <td class="py-3 pr-4 text-fumo text-xs">{m.matchday}</td>
            <td class="py-3 pr-4 text-panna">{m.home.name} – {m.away.name}</td>
            <td class="py-3 pr-4 text-fumo text-xs">{m.date} · {m.time}</td>
            <td class="py-3 pr-4">
              <span class={`font-display text-[0.65rem] tracking-wider uppercase px-2 py-1 ${
                m.status === "finished" ? "bg-carbone text-fumo" :
                m.status === "live" ? "bg-rosso text-panna" :
                "bg-oro/20 text-oro"
              }`}>{m.status}</span>
            </td>
            <td class="py-3 pr-4 tabular-nums">{m.score ? `${m.score.home}–${m.score.away}` : "—"}</td>
            <td class="py-3 flex gap-2 justify-end">
              <a href={`/admin/matches/${m.id}`} class="btn btn-ghost text-xs">Modifica</a>
              <form method="post" onsubmit="return confirm('Eliminare questa partita?')">
                <input type="hidden" name="action" value="delete" />
                <input type="hidden" name="id" value={m.id} />
                <button type="submit" class="btn btn-ghost text-xs text-rosso">Elimina</button>
              </form>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</AdminLayout>
