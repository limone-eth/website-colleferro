---
import AdminLayout from "@/layouts/AdminLayout.astro";
import ImageUploader from "@/components/admin/ImageUploader.astro";
import { requireAdmin } from "@/lib/auth";
import { getYouthStadium, setYouthStadium } from "@/lib/settings";

const guard = requireAdmin(Astro);
if (guard) return guard;

let notice: string | undefined;
let error: string | undefined;

if (Astro.request.method === "POST") {
  const f = await Astro.request.formData();
  try {
    await setYouthStadium({
      name: String(f.get("name") ?? "").trim(),
      address: String(f.get("address") ?? "").trim(),
      city: String(f.get("city") ?? "").trim(),
      description: String(f.get("description") ?? "").trim(),
      photoUrl: String(f.get("photoUrl") ?? "").trim(),
      mapsUrl: String(f.get("mapsUrl") ?? "").trim(),
    });
    notice = "Salvato.";
  } catch (e) {
    error = (e as Error).message;
  }
}

const stadium = await getYouthStadium();
---

<AdminLayout title="Stadio settore giovanile" current="youth">
  <div class="mb-6 border-b border-carbone pb-4">
    <p class="font-display text-[0.65rem] tracking-[0.25em] uppercase text-oro mb-1">Settore Giovanile</p>
    <h1 class="font-display text-2xl text-panna">Stadio / Campo del settore giovanile</h1>
    <p class="text-fumo text-xs mt-2">Queste info appaiono sulla pagina pubblica del settore giovanile.</p>
  </div>

  {notice && <p class="mb-4 text-sm text-oro border border-oro/40 bg-oro/10 px-3 py-2">{notice}</p>}
  {error && <p class="mb-4 text-sm text-rosso border border-rosso/40 bg-rosso/10 px-3 py-2">{error}</p>}

  <form method="post" class="space-y-5 bg-grafite border border-carbone p-6">
    <div class="grid md:grid-cols-2 gap-4">
      <label class="block">
        <span class="font-display text-xs uppercase text-fumo block mb-2">Nome impianto</span>
        <input name="name" value={stadium.name} placeholder='Campo "Esempio"' class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
      </label>
      <label class="block">
        <span class="font-display text-xs uppercase text-fumo block mb-2">Città</span>
        <input name="city" value={stadium.city} placeholder="Colleferro (RM)" class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
      </label>
    </div>
    <label class="block">
      <span class="font-display text-xs uppercase text-fumo block mb-2">Indirizzo</span>
      <input name="address" value={stadium.address} placeholder="Via …, n. …" class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
    </label>
    <label class="block">
      <span class="font-display text-xs uppercase text-fumo block mb-2">URL Google Maps (opzionale)</span>
      <input type="url" name="mapsUrl" value={stadium.mapsUrl} placeholder="https://maps.google.com/…" class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
    </label>
    <label class="block">
      <span class="font-display text-xs uppercase text-fumo block mb-2">Descrizione</span>
      <textarea name="description" rows="4" class="w-full bg-nero border border-carbone px-3 py-2 text-panna">{stadium.description}</textarea>
    </label>
    <ImageUploader
      name="photoUrl"
      value={stadium.photoUrl}
      folder="colleferro/youth"
      label="Foto impianto (opzionale)"
      hint="jpg, png, webp · max 5MB"
    />
    <div class="flex gap-3 pt-2">
      <button type="submit" class="btn btn-primary">Salva</button>
      <a href="/admin/youth" class="btn btn-ghost">Indietro</a>
    </div>
  </form>
</AdminLayout>
