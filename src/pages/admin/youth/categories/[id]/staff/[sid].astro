---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { requireAdmin } from "@/lib/auth";
import { db, getYouthCategoryById } from "@/lib/db";
import { upsertStaff } from "@/lib/db-write";
import { formatSeason } from "@/lib/season";
import ImageUploader from "@/components/admin/ImageUploader.astro";

const guard = requireAdmin(Astro);
if (guard) return guard;

const { id, sid } = Astro.params;
if (!id || !sid) return Astro.redirect("/admin/youth");
const catId = Number(id);
const staffId = Number(sid);

const category = await getYouthCategoryById(catId);
if (!category) return new Response("Categoria non trovata", { status: 404 });

const { rows } = await db.execute({ sql: "SELECT * FROM staff WHERE id = ?", args: [staffId] });
if (!rows[0]) return new Response("Membro non trovato", { status: 404 });
const r = rows[0];

let error: string | undefined;

if (Astro.request.method === "POST") {
  const f = await Astro.request.formData();
  try {
    await upsertStaff({
      season: Number(r.season),
      name: String(f.get("name") ?? "").trim(),
      role: String(f.get("role") ?? "").trim(),
      group: String(f.get("group") ?? "") as "Tecnico" | "Medico" | "Dirigenza",
      ordering: Number(f.get("ordering") ?? 0),
      photoUrl: (f.get("photoUrl") as string) || null,
      youthCategoryId: catId,
      isYouthManagement: false,
    }, staffId);
    return Astro.redirect(`/admin/youth/categories/${catId}/staff`);
  } catch (e) {
    error = (e as Error).message;
  }
}

const groups = ["Tecnico", "Medico", "Dirigenza"] as const;
---

<AdminLayout title="Modifica tecnico" current="youth">
  <h1 class="font-display text-2xl text-panna mb-2">Modifica tecnico · {category.name}</h1>
  <p class="text-fumo text-xs mb-6">Stagione {formatSeason(category.season)}</p>

  <form method="post" class="bg-grafite border border-carbone p-6 grid md:grid-cols-5 gap-4 items-end">
    {error && <p class="text-sm text-rosso border border-rosso/40 bg-rosso/10 px-3 py-2 md:col-span-5">{error}</p>}
    <label class="block md:col-span-2">
      <span class="font-display text-xs uppercase text-fumo block mb-1">Nome</span>
      <input name="name" required value={r.name as string} class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
    </label>
    <label class="block md:col-span-2">
      <span class="font-display text-xs uppercase text-fumo block mb-1">Ruolo</span>
      <input name="role" required value={r.role as string} class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
    </label>
    <label class="block">
      <span class="font-display text-xs uppercase text-fumo block mb-1">Gruppo</span>
      <select name="group" required class="w-full bg-nero border border-carbone px-3 py-2 text-panna">
        {groups.map((g) => <option value={g} selected={r.grp === g}>{g}</option>)}
      </select>
    </label>
    <label class="block">
      <span class="font-display text-xs uppercase text-fumo block mb-1">Ordine</span>
      <input type="number" name="ordering" value={r.ordering as number} class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
    </label>
    <div class="md:col-span-5">
      <ImageUploader
        name="photoUrl"
        value={(r.photo_url as string | null) ?? ""}
        folder="colleferro/staff"
        label="Foto"
        hint="verticale 3:4 · jpg/png/webp · max 5MB"
        cropAspectRatio={3 / 4}
      />
    </div>
    <div class="md:col-span-5 flex gap-3 pt-2">
      <button type="submit" class="btn btn-primary">Salva</button>
      <a href={`/admin/youth/categories/${catId}/staff`} class="btn btn-ghost">Annulla</a>
    </div>
  </form>
</AdminLayout>
