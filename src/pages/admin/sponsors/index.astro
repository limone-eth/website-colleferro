---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { requireAdmin } from "@/lib/auth";
import { getSponsors } from "@/lib/db";
import { upsertSponsor, deleteSponsor } from "@/lib/db-write";
import { resolveAdminSeason, formatSeason } from "@/lib/season";

const guard = requireAdmin(Astro);
if (guard) return guard;

const season = await resolveAdminSeason(Astro.cookies);

let error: string | undefined;

if (Astro.request.method === "POST") {
  const f = await Astro.request.formData();
  const action = f.get("action");
  try {
    if (action === "delete") {
      await deleteSponsor(Number(f.get("id")));
    } else if (action === "create") {
      await upsertSponsor({
        season,
        name: String(f.get("name") ?? "").trim(),
        tier: String(f.get("tier") ?? "") as "Main" | "Technical" | "Official" | "Local",
        url: (f.get("url") as string) || null,
        ordering: Number(f.get("ordering") ?? 0),
      });
    }
    return Astro.redirect("/admin/sponsors");
  } catch (e) {
    error = (e as Error).message;
  }
}

const sponsors = await getSponsors(season);
const tiers = ["Main", "Technical", "Official", "Local"] as const;
---

<AdminLayout title="Sponsor" current="sponsors">
  <div class="mb-6 border-b border-carbone pb-4">
    <p class="font-display text-[0.65rem] tracking-[0.25em] uppercase text-oro mb-1">Sponsor · Stagione {formatSeason(season)}</p>
    <h1 class="font-display text-2xl text-panna">Partner del club</h1>
  </div>

  {error && <p class="mb-4 text-sm text-rosso border border-rosso/40 bg-rosso/10 px-3 py-2">{error}</p>}

  <form method="post" class="bg-grafite border border-carbone p-5 grid md:grid-cols-5 gap-3 items-end mb-8">
    <input type="hidden" name="action" value="create" />
    <label class="block md:col-span-2">
      <span class="font-display text-xs uppercase text-fumo block mb-1">Nome</span>
      <input name="name" required class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
    </label>
    <label class="block">
      <span class="font-display text-xs uppercase text-fumo block mb-1">Tier</span>
      <select name="tier" required class="w-full bg-nero border border-carbone px-3 py-2 text-panna">
        {tiers.map((t) => <option value={t}>{t}</option>)}
      </select>
    </label>
    <label class="block">
      <span class="font-display text-xs uppercase text-fumo block mb-1">URL (opz.)</span>
      <input name="url" placeholder="https://…" class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
    </label>
    <label class="block">
      <span class="font-display text-xs uppercase text-fumo block mb-1">Ordine</span>
      <input type="number" name="ordering" value={sponsors.length} class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
    </label>
    <div class="md:col-span-5">
      <button type="submit" class="btn btn-primary">Aggiungi</button>
    </div>
  </form>

  <table class="w-full text-sm">
    <thead class="border-b border-carbone">
      <tr class="text-left text-fumo font-display text-xs tracking-wider uppercase">
        <th class="py-3 pr-4">Tier</th>
        <th class="py-3 pr-4">Nome</th>
        <th class="py-3 pr-4">URL</th>
        <th class="py-3"></th>
      </tr>
    </thead>
    <tbody>
      {sponsors.map((s) => (
        <tr class="border-b border-carbone/60">
          <td class="py-3 pr-4"><span class="font-display text-[0.65rem] tracking-wider uppercase bg-carbone text-oro px-2 py-1">{s.tier}</span></td>
          <td class="py-3 pr-4 text-panna">{s.name}</td>
          <td class="py-3 pr-4 text-fumo text-xs truncate max-w-sm">{s.url ?? "—"}</td>
          <td class="py-3 flex gap-2 justify-end">
            <a href={`/admin/sponsors/${s.id}`} class="btn btn-ghost text-xs">Modifica</a>
            <form method="post" onsubmit="return confirm('Eliminare questo sponsor?')">
              <input type="hidden" name="action" value="delete" />
              <input type="hidden" name="id" value={s.id} />
              <button type="submit" class="btn btn-ghost text-xs text-rosso">Elimina</button>
            </form>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</AdminLayout>
