---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { requireAdmin } from "@/lib/auth";
import { db } from "@/lib/db";
import { upsertSponsor } from "@/lib/db-write";
import { formatSeason } from "@/lib/season";
import ImageUploader from "@/components/admin/ImageUploader.astro";
import { assertValidImageUrl, IMAGE_RULES } from "@/lib/image-validation";

const guard = requireAdmin(Astro);
if (guard) return guard;

const { id } = Astro.params;
if (!id) return Astro.redirect("/admin/sponsors");
const idNum = Number(id);

const { rows } = await db.execute({ sql: "SELECT * FROM sponsors WHERE id = ?", args: [idNum] });
if (!rows[0]) return new Response("Sponsor non trovato", { status: 404 });
const r = rows[0];
const sponsorSeason = Number(r.season);

let error: string | undefined;

if (Astro.request.method === "POST") {
  const f = await Astro.request.formData();
  try {
    const logoUrl = (f.get("logoUrl") as string) || null;
    await assertValidImageUrl(logoUrl, { ...IMAGE_RULES.sponsorLogo, requiredFolder: "colleferro/sponsors" });
    await upsertSponsor({
      season: sponsorSeason,
      name: String(f.get("name") ?? "").trim(),
      tier: String(f.get("tier") ?? "") as "Main" | "Technical" | "Official" | "Local",
      url: (f.get("url") as string) || null,
      ordering: Number(f.get("ordering") ?? 0),
      logoUrl,
    }, idNum);
    return Astro.redirect("/admin/sponsors");
  } catch (e) {
    error = (e as Error).message;
  }
}
const tiers = ["Main", "Technical", "Official", "Local"] as const;
---

<AdminLayout title="Modifica sponsor" current="sponsors">
  <h1 class="font-display text-2xl text-panna mb-2">Modifica sponsor</h1>
  <p class="text-fumo text-xs mb-6">Stagione {formatSeason(sponsorSeason)}</p>

  <form method="post" class="bg-grafite border border-carbone p-6 grid md:grid-cols-5 gap-4 items-end">
    {error && <p class="text-sm text-rosso border border-rosso/40 bg-rosso/10 px-3 py-2 md:col-span-5">{error}</p>}
    <label class="block md:col-span-2">
      <span class="font-display text-xs uppercase text-fumo block mb-1">Nome</span>
      <input name="name" required value={r.name as string} class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
    </label>
    <label class="block">
      <span class="font-display text-xs uppercase text-fumo block mb-1">Tier</span>
      <select name="tier" required class="w-full bg-nero border border-carbone px-3 py-2 text-panna">
        {tiers.map((t) => <option value={t} selected={r.tier === t}>{t}</option>)}
      </select>
    </label>
    <label class="block">
      <span class="font-display text-xs uppercase text-fumo block mb-1">URL</span>
      <input name="url" value={(r.url as string | null) ?? ""} class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
    </label>
    <label class="block">
      <span class="font-display text-xs uppercase text-fumo block mb-1">Ordine</span>
      <input type="number" name="ordering" value={r.ordering as number} class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
    </label>
    <div class="md:col-span-5">
      <ImageUploader
        name="logoUrl"
        value={(r.logo_url as string | null) ?? ""}
        folder="colleferro/sponsors"
        label="Logo sponsor"
        hint="orizzontale (largh ≥ 1,5× altezza) · png/svg con trasparenza · max 2MB"
        formats={IMAGE_RULES.sponsorLogo.allowedFormats}
        maxBytes={IMAGE_RULES.sponsorLogo.maxBytes}
        cropMinAspectRatio={1.5}
      />
    </div>
    <div class="md:col-span-5 flex gap-3 pt-2">
      <button type="submit" class="btn btn-primary">Salva</button>
      <a href="/admin/sponsors" class="btn btn-ghost">Annulla</a>
    </div>
  </form>
</AdminLayout>
