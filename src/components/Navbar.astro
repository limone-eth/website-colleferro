---
const nav = [
  {
    label: "Club",
    children: [
      { label: "Storia", href: "/storia" },
      { label: "Lo Stadio", href: "/stadio" },
    ],
  },
  {
    label: "Squadra",
    children: [
      { label: "Prima Squadra", href: "/squadra/prima-squadra" },
      { label: "Staff", href: "/squadra/staff" },
    ],
  },
  { label: "Stagione", href: "/stagione" },
  { label: "News", href: "/news" },
  { label: "Contatti", href: "/contatti" },
  { label: "Shop", href: "/shop" },
  { label: "Media", href: "/media" },
  { label: "Sponsor", href: "/sponsor" },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<header class="sticky top-0 z-40 bg-nero/95 backdrop-blur border-b border-rosso/40">
  <div class="stripe-diagonal h-1"></div>

  <div class="max-w-7xl mx-auto px-5 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20 gap-6">
      <a href="/" class="flex items-center gap-3 group" aria-label="Colleferro Calcio — Home">
        <span class="w-10 h-10 lg:w-11 lg:h-11 grid place-items-center bg-rosso">
          <svg viewBox="0 0 32 32" class="w-6 h-6 fill-oro" aria-hidden="true">
            <path d="M16 4l3 6.2 6.8 1-5 4.8 1.2 6.8L16 19.6 10 22.8l1.2-6.8-5-4.8 6.8-1L16 4z" />
          </svg>
        </span>
        <span class="font-display text-panna leading-none">
          <span class="block text-[0.65rem] tracking-[0.2em] text-fumo uppercase">A.S.D.</span>
          <span class="block text-lg lg:text-xl tracking-wide">Colleferro Calcio</span>
        </span>
      </a>

      <nav class="hidden lg:flex items-center gap-1" aria-label="Navigazione principale">
        {
          nav.map((item) =>
            item.children ? (
              <div class="relative group">
                <button
                  type="button"
                  class={`px-3 py-2 font-display text-sm uppercase tracking-wider transition-colors cursor-pointer ${
                    item.children.some((c) => isActive(c.href))
                      ? "text-oro"
                      : "text-panna hover:text-oro"
                  }`}
                  aria-haspopup="true"
                >
                  {item.label}
                  <svg class="inline-block ml-1 w-3 h-3" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true">
                    <path d="M2 4l4 4 4-4z" />
                  </svg>
                </button>
                <div class="absolute top-full left-0 min-w-[12rem] bg-grafite border border-rosso/40 opacity-0 invisible group-hover:opacity-100 group-hover:visible focus-within:opacity-100 focus-within:visible transition-opacity">
                  {item.children.map((c) => (
                    <a
                      href={c.href}
                      class={`block px-4 py-2.5 font-display text-sm uppercase tracking-wider border-l-2 transition-colors ${
                        isActive(c.href)
                          ? "text-oro border-oro bg-nero"
                          : "text-panna border-transparent hover:border-rosso hover:text-oro"
                      }`}
                    >
                      {c.label}
                    </a>
                  ))}
                </div>
              </div>
            ) : (
              <a
                href={item.href}
                class={`px-3 py-2 font-display text-sm uppercase tracking-wider transition-colors ${
                  isActive(item.href) ? "text-oro" : "text-panna hover:text-oro"
                }`}
              >
                {item.label}
              </a>
            )
          )
        }
      </nav>

      <a
        href="/biglietteria"
        class="hidden md:inline-flex btn btn-oro text-sm"
      >
        Biglietteria
      </a>

      <button
        type="button"
        id="menuToggle"
        class="lg:hidden grid place-items-center w-10 h-10 text-panna hover:text-oro cursor-pointer"
        aria-label="Apri menu"
        aria-expanded="false"
        aria-controls="mobileMenu"
      >
        <svg viewBox="0 0 24 24" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="square" d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobileMenu" class="hidden lg:hidden border-t border-rosso/40 bg-grafite">
    <nav class="px-5 py-4 flex flex-col" aria-label="Navigazione mobile">
      {
        nav.map((item) =>
          item.children ? (
            <div class="py-2 border-b border-carbone last:border-b-0">
              <p class="font-display text-xs uppercase tracking-[0.2em] text-fumo mb-2">
                {item.label}
              </p>
              {item.children.map((c) => (
                <a
                  href={c.href}
                  class={`block py-2 font-display text-sm uppercase tracking-wider ${
                    isActive(c.href) ? "text-oro" : "text-panna"
                  }`}
                >
                  {c.label}
                </a>
              ))}
            </div>
          ) : (
            <a
              href={item.href}
              class={`py-3 font-display text-sm uppercase tracking-wider border-b border-carbone last:border-b-0 ${
                isActive(item.href) ? "text-oro" : "text-panna"
              }`}
            >
              {item.label}
            </a>
          )
        )
      }
      <a href="/biglietteria" class="btn btn-oro mt-4 justify-center">Biglietteria</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("menuToggle");
  const menu = document.getElementById("mobileMenu");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Chiudi menu" : "Apri menu");
  });
</script>
