---
import type { Match } from "@/lib/db";
interface Props {
  action: string;
  match?: Match;
  error?: string;
}
const { action, match, error } = Astro.props;
---

<form method="post" action={action} class="space-y-5 bg-grafite border border-carbone p-6">
  {error && <p class="text-sm text-rosso border border-rosso/40 bg-rosso/10 px-3 py-2">{error}</p>}

  <div class="grid md:grid-cols-2 gap-4">
    <label class="block">
      <span class="font-display text-xs uppercase text-fumo block mb-2">ID (es. m-08)</span>
      <input name="id" required value={match?.id ?? ""} class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
    </label>
    <label class="block">
      <span class="font-display text-xs uppercase text-fumo block mb-2">Giornata</span>
      <input name="matchday" required value={match?.matchday ?? ""} placeholder="26ª Giornata" class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
    </label>
    <label class="block md:col-span-2">
      <span class="font-display text-xs uppercase text-fumo block mb-2">Competizione</span>
      <input name="competition" required value={match?.competition ?? "Eccellenza Lazio — Girone B"} class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
    </label>
  </div>

  <div class="grid md:grid-cols-3 gap-4 items-end">
    <label class="block md:col-span-2">
      <span class="font-display text-xs uppercase text-fumo block mb-2">Data estesa (es. Domenica 26 Aprile 2026)</span>
      <input name="dateLong" required value={match?.dateLong ?? ""} class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
    </label>
    <label class="block">
      <span class="font-display text-xs uppercase text-fumo block mb-2">Ora (HH:MM)</span>
      <input name="time" required value={match?.time ?? "15:00"} class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
    </label>
    <label class="block">
      <span class="font-display text-xs uppercase text-fumo block mb-2">Data breve (es. 26 APR)</span>
      <input name="date" required value={match?.date ?? ""} class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
    </label>
    <label class="block md:col-span-2">
      <span class="font-display text-xs uppercase text-fumo block mb-2">Stadio</span>
      <input name="venue" required value={match?.venue ?? ""} class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
    </label>
  </div>

  <div class="grid md:grid-cols-4 gap-4">
    <label class="block md:col-span-2">
      <span class="font-display text-xs uppercase text-fumo block mb-2">Casa — Nome</span>
      <input name="homeName" required value={match?.home.name ?? ""} class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
    </label>
    <label class="block">
      <span class="font-display text-xs uppercase text-fumo block mb-2">Casa — Sigla</span>
      <input name="homeShort" required maxlength="4" value={match?.home.short ?? ""} class="w-full bg-nero border border-carbone px-3 py-2 text-panna uppercase" />
    </label>
    <label class="block">
      <span class="font-display text-xs uppercase text-fumo block mb-2">Casa — Gol</span>
      <input type="number" name="scoreHome" min="0" value={match?.score?.home ?? ""} class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
    </label>

    <label class="block md:col-span-2">
      <span class="font-display text-xs uppercase text-fumo block mb-2">Ospite — Nome</span>
      <input name="awayName" required value={match?.away.name ?? ""} class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
    </label>
    <label class="block">
      <span class="font-display text-xs uppercase text-fumo block mb-2">Ospite — Sigla</span>
      <input name="awayShort" required maxlength="4" value={match?.away.short ?? ""} class="w-full bg-nero border border-carbone px-3 py-2 text-panna uppercase" />
    </label>
    <label class="block">
      <span class="font-display text-xs uppercase text-fumo block mb-2">Ospite — Gol</span>
      <input type="number" name="scoreAway" min="0" value={match?.score?.away ?? ""} class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
    </label>
  </div>

  <div class="grid md:grid-cols-2 gap-4">
    <label class="block">
      <span class="font-display text-xs uppercase text-fumo block mb-2">Stato</span>
      <select name="status" required class="w-full bg-nero border border-carbone px-3 py-2 text-panna">
        <option value="upcoming" selected={match?.status === "upcoming" || !match}>In programma</option>
        <option value="live" selected={match?.status === "live"}>In corso</option>
        <option value="finished" selected={match?.status === "finished"}>Conclusa</option>
      </select>
    </label>
    <label class="block">
      <span class="font-display text-xs uppercase text-fumo block mb-2">URL biglietteria (opzionale)</span>
      <input name="ticketUrl" value={match?.ticketUrl ?? ""} placeholder="/biglietteria" class="w-full bg-nero border border-carbone px-3 py-2 text-panna" />
    </label>
  </div>

  <div class="flex gap-3 pt-2">
    <button type="submit" class="btn btn-primary">Salva</button>
    <a href="/admin/matches" class="btn btn-ghost">Annulla</a>
  </div>
</form>
