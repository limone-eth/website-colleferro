---
interface Props {
  url: string;
  label?: string;
  class?: string;
}
const { url, label = "Condividi su Facebook", class: className = "" } = Astro.props;
const href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`;
---
<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class={`btn btn-ghost text-sm inline-flex items-center gap-2 ${className}`}
  aria-label={label}
>
  <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor" aria-hidden="true">
    <path d="M13.5 21.5v-8h2.7l.4-3.2h-3.1V8.2c0-.9.3-1.5 1.6-1.5h1.7V3.9c-.3 0-1.3-.1-2.4-.1-2.4 0-4 1.5-4 4.1v2.4H8v3.2h2.4v8h3.1z" />
  </svg>
  <span>Facebook</span>
</a>
