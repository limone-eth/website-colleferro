---
interface Sponsor {
  name: string;
  tier: "Main" | "Technical" | "Official" | "Local";
  url?: string;
}
interface Props {
  sponsors: Sponsor[];
  variant?: "strip" | "grid";
}
const { sponsors, variant = "strip" } = Astro.props;
---

{
  variant === "strip" ? (
    <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-6">
      {sponsors.map((s) => (
        <a
          href={s.url || "#"}
          class="group flex flex-col items-center gap-1 text-fumo hover:text-panna transition-colors"
        >
          <span class="font-display text-[0.6rem] tracking-[0.25em] uppercase text-fumo/70">
            {s.tier}
          </span>
          <span class="font-display text-xl md:text-2xl tracking-wide grayscale group-hover:grayscale-0">
            {s.name}
          </span>
        </a>
      ))}
    </div>
  ) : (
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {sponsors.map((s) => (
        <a
          href={s.url || "#"}
          class="group bg-grafite border border-carbone hover:border-oro/60 p-6 text-center transition-colors"
        >
          <span class="block font-display text-[0.6rem] tracking-[0.25em] uppercase text-oro mb-2">
            {s.tier}
          </span>
          <span class="font-display text-lg md:text-xl text-panna group-hover:text-oro transition-colors">
            {s.name}
          </span>
        </a>
      ))}
    </div>
  )
}
