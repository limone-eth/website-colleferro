---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  variant?: "home" | "page";
  bgImage?: { jpg: string; webp?: string };
}
const {
  eyebrow,
  title,
  subtitle,
  primaryCta,
  secondaryCta,
  variant = "page",
  bgImage,
} = Astro.props;

const resolvedBg = bgImage;
---

<section class={`relative overflow-hidden ${variant === "home" ? "min-h-[78vh]" : "min-h-[44vh]"} bg-nero`}>
  {resolvedBg && (
    <picture>
      {resolvedBg.webp && <source srcset={resolvedBg.webp} type="image/webp" />}
      <img
        src={resolvedBg.jpg}
        alt=""
        aria-hidden="true"
        class="absolute inset-0 w-full h-full object-cover object-top opacity-55"
      />
    </picture>
  )}
  {resolvedBg && (
    <div class="absolute inset-0 bg-gradient-to-t from-nero via-nero/60 to-nero/20"></div>
  )}
  <div class="absolute inset-0 opacity-40 bg-[radial-gradient(ellipse_at_top,_var(--color-rosso)_0%,_transparent_55%)]"></div>
  <div class="absolute inset-y-0 right-0 w-1/2 opacity-10 bg-[radial-gradient(ellipse_at_right,_var(--color-oro)_0%,_transparent_60%)]"></div>

  <div class="absolute -right-20 -top-20 w-[42rem] h-[42rem] rotate-12 stripe-diagonal opacity-[0.06]" aria-hidden="true"></div>

  <div class="relative max-w-7xl mx-auto px-5 lg:px-8 py-20 lg:py-28 flex flex-col justify-center min-h-[inherit]">
    <picture>
      <source srcset="/logo.webp" type="image/webp" />
      <img
        src="/logo.png"
        alt=""
        width="200"
        height="200"
        class={`${variant === "home" ? "w-32 md:w-40" : "w-24 md:w-28"} h-auto mb-6 drop-shadow-[0_8px_24px_rgba(0,0,0,0.5)]`}
      />
    </picture>
    {eyebrow && (
      <p class="font-display text-xs tracking-[0.3em] uppercase text-oro mb-5">
        <span class="inline-block w-8 h-px bg-oro align-middle mr-3"></span>
        {eyebrow}
      </p>
    )}
    <h1 class={`font-display font-bold text-panna leading-[0.95] ${variant === "home" ? "text-5xl md:text-7xl lg:text-8xl" : "text-4xl md:text-6xl"} max-w-5xl`}>
      <slot name="title">{title}</slot>
    </h1>
    {subtitle && (
      <p class="mt-6 text-lg md:text-xl text-panna/80 max-w-2xl leading-relaxed">
        {subtitle}
      </p>
    )}
    {(primaryCta || secondaryCta) && (
      <div class="mt-10 flex flex-wrap gap-3">
        {primaryCta && (
          <a href={primaryCta.href} class="btn btn-primary">
            {primaryCta.label}
            <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="square" />
            </svg>
          </a>
        )}
        {secondaryCta && (
          <a href={secondaryCta.href} class="btn btn-ghost">{secondaryCta.label}</a>
        )}
      </div>
    )}
  </div>

  <div class="stripe-diagonal h-1 w-full"></div>
</section>
