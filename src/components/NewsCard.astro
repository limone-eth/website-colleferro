---
interface Props {
  slug: string;
  title: string;
  excerpt: string;
  date: string;
  category: string;
  image?: string;
  featured?: boolean;
}
const { slug, title, excerpt, date, category, image, featured = false } = Astro.props;
---

<article class={`group relative bg-grafite border border-carbone hover:border-rosso/60 transition-colors overflow-hidden ${featured ? "md:col-span-2 md:row-span-2" : ""}`}>
  <a href={`/news/${slug}`} class="block h-full">
    <div class={`relative overflow-hidden bg-carbone ${featured ? "aspect-[16/10]" : "aspect-[16/9]"}`}>
      {image ? (
        <img
          src={image}
          alt=""
          loading="lazy"
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      ) : (
        <div class="w-full h-full grid place-items-center bg-gradient-to-br from-rosso-deep via-nero to-carbone">
          <svg viewBox="0 0 64 64" class="w-16 h-16 fill-oro/40" aria-hidden="true">
            <path d="M32 4l6 13 14 2-10 10 2.4 14L32 36l-12.4 7 2.4-14-10-10 14-2 6-13z" />
          </svg>
        </div>
      )}
      <span class="absolute top-4 left-4 font-display text-[0.65rem] tracking-[0.2em] uppercase bg-rosso text-panna px-3 py-1">
        {category}
      </span>
    </div>

    <div class="p-5 md:p-6">
      <p class="font-display text-xs tracking-[0.2em] uppercase text-fumo mb-2">
        {date}
      </p>
      <h3 class={`font-display font-bold text-panna group-hover:text-oro transition-colors leading-tight ${featured ? "text-2xl md:text-3xl" : "text-lg md:text-xl"}`}>
        {title}
      </h3>
      <p class={`text-fumo mt-3 leading-relaxed ${featured ? "text-base line-clamp-3" : "text-sm line-clamp-2"}`}>
        {excerpt}
      </p>
      <span class="inline-flex items-center gap-2 mt-4 font-display text-xs tracking-[0.2em] uppercase text-oro">
        Leggi
        <svg viewBox="0 0 24 24" class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="square" />
        </svg>
      </span>
    </div>
  </a>
</article>
